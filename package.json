{
  "name": "tenora",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "pnpm --filter @tenora/db db:migrate",
    "db:generate": "pnpm --filter @tenora/db db:generate",
    "db:studio": "pnpm --filter @tenora/db db:studio",
    "db:seed": "pnpm --filter @tenora/db db:seed",
    "db:reset": "pnpm --filter @tenora/db db:reset"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
