# =============================================================================
# TENORA — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores
#
#   cp .env.example .env
#
# NUNCA commite o arquivo .env no repositório.
# O .env.example é o único que deve ser versionado.
# =============================================================================


# -----------------------------------------------------------------------------
# AMBIENTE
# -----------------------------------------------------------------------------

NODE_ENV="development"
# Valores aceitos: development | staging | production

LOG_LEVEL="info"
# Valores aceitos: debug | info | warn | error
# Use "debug" em desenvolvimento para ver todas as queries do Prisma


# -----------------------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://tenora_app:SENHA_AQUI@localhost:5432/tenora_dev"
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
#
# Usuário da aplicação — sujeito ao RLS (Row Level Security)
# NÃO use o usuário postgres aqui — ele bypassa o RLS e é um risco de segurança
#
# Para criar o usuário e banco no PostgreSQL:
#   CREATE USER tenora_app WITH PASSWORD 'SENHA_AQUI';
#   CREATE DATABASE tenora_dev OWNER tenora_app;
#   GRANT ALL PRIVILEGES ON DATABASE tenora_dev TO tenora_app;

DATABASE_URL_MIGRATOR="postgresql://tenora_migrator:SENHA_AQUI@localhost:5432/tenora_dev"
# Usuário exclusivo para rodar migrations — tem BYPASSRLS
# Usado apenas nos scripts db:migrate e db:reset — nunca pela aplicação
#
# Para criar:
#   CREATE USER tenora_migrator WITH PASSWORD 'SENHA_AQUI' NOSUPERUSER BYPASSRLS;
#   GRANT ALL ON ALL TABLES IN SCHEMA public TO tenora_migrator;
#   GRANT ALL ON ALL SEQUENCES IN SCHEMA public TO tenora_migrator;

DATABASE_SHADOW_URL="postgresql://tenora_migrator:SENHA_AQUI@localhost:5432/tenora_shadow"
# Banco shadow usado pelo Prisma para validar migrations antes de aplicar
# Precisa existir e o usuário migrator precisa ter acesso total
#
# Para criar:
#   CREATE DATABASE tenora_shadow OWNER tenora_migrator;

DATABASE_POOL_MIN="2"
DATABASE_POOL_MAX="10"
# Tamanho do connection pool — ajuste conforme o plano do banco em produção
# Railway free tier: máximo 10 conexões simultâneas


# -----------------------------------------------------------------------------
# REDIS — BullMQ e cache
# -----------------------------------------------------------------------------

REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
# Deixe em branco para desenvolvimento local sem senha
# Em produção (Railway, Upstash), sempre use senha

REDIS_URL="redis://localhost:6379"
# URL completa — alternativa às variáveis individuais acima
# Formato com senha: redis://:SENHA@HOST:PORTA


# -----------------------------------------------------------------------------
# API — Servidor Fastify
# -----------------------------------------------------------------------------

API_PORT="3001"
# Porta do servidor backend (Fastify + tRPC)

API_HOST="0.0.0.0"
# 0.0.0.0 para aceitar conexões externas (necessário no Docker)
# 127.0.0.1 para aceitar apenas conexões locais

API_URL="http://localhost:3001"
# URL base da API — usada pelo web para construir chamadas tRPC


# -----------------------------------------------------------------------------
# WEB — Next.js
# -----------------------------------------------------------------------------

NEXT_PUBLIC_API_URL="http://localhost:3001"
# URL da API acessível pelo browser (variável pública — exposta ao cliente)

NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL base do app web — usada para gerar links absolutos (emails, redirects)


# -----------------------------------------------------------------------------
# CLERK — Autenticação e multi-tenant
# -----------------------------------------------------------------------------
# Crie sua conta em: https://clerk.com
# Crie um novo Application e copie as chaves do dashboard

CLERK_SECRET_KEY=""
# Chave secreta — usada apenas no backend (Fastify)
# Formato: sk_test_... (desenvolvimento) | sk_live_... (produção)
# NUNCA exponha esta chave no frontend

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# Chave pública — usada no frontend (Next.js)
# Formato: pk_test_... (desenvolvimento) | pk_live_... (produção)

CLERK_WEBHOOK_SECRET=""
# Secret para validar webhooks do Clerk (user.created, user.updated, etc.)
# Gere em: Clerk Dashboard → Webhooks → seu endpoint → Signing Secret
# Formato: whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/cadastro"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"
# Rotas de redirecionamento do Clerk — ajuste conforme as rotas do Next.js


# -----------------------------------------------------------------------------
# STRIPE — Billing e assinaturas
# -----------------------------------------------------------------------------
# Crie sua conta em: https://stripe.com
# Use as chaves de teste para development e staging

STRIPE_SECRET_KEY=""
# Chave secreta — usada apenas no backend
# Formato: sk_test_... (desenvolvimento) | sk_live_... (produção)

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Chave pública — usada no frontend para o Stripe.js
# Formato: pk_test_... (desenvolvimento) | pk_live_... (produção)

STRIPE_WEBHOOK_SECRET=""
# Secret para validar webhooks do Stripe (invoice.paid, subscription.updated, etc.)
# Gere em: Stripe Dashboard → Developers → Webhooks → seu endpoint → Signing secret
# Formato: whsec_...

STRIPE_PRICE_STARTER=""
# ID do Price do plano Starter (R$397/mês) no Stripe
# Formato: price_...

STRIPE_PRICE_PRO=""
# ID do Price do plano Pro (R$697/mês) no Stripe

STRIPE_PRICE_SCALE=""
# ID do Price do plano Scale (R$1.197/mês) no Stripe


# -----------------------------------------------------------------------------
# PLUGGY — Integração bancária Open Finance
# -----------------------------------------------------------------------------
# Crie sua conta em: https://pluggy.ai
# Acesse o sandbox em: https://my.pluggy.ai

PLUGGY_CLIENT_ID=""
# Client ID da sua aplicação no Pluggy
# Encontre em: Pluggy Dashboard → Applications → seu app

PLUGGY_CLIENT_SECRET=""
# Client Secret — mantenha seguro, nunca exponha no frontend

PLUGGY_WEBHOOK_SECRET=""
# Secret para validar webhooks do Pluggy (transaction.created, etc.)
# Configure em: Pluggy Dashboard → Webhooks

PLUGGY_ENV="sandbox"
# Valores: sandbox | production
# Use sandbox para desenvolvimento e testes com dados simulados


# -----------------------------------------------------------------------------
# PSP — Pagamentos PIX e Boleto
# -----------------------------------------------------------------------------
# Escolha um dos provedores abaixo e preencha as variáveis correspondentes
# Opções avaliadas: Asaas, Pagar.me, Stripe BR

# -- Asaas (recomendado para o MVP) --
# Crie sua conta em: https://asaas.com
ASAAS_API_KEY=""
# Formato: $aact_... (produção) | $aatp_... (sandbox)

ASAAS_ENV="sandbox"
# Valores: sandbox | production

ASAAS_WEBHOOK_TOKEN=""
# Token para validar webhooks do Asaas (PAYMENT_RECEIVED, etc.)


# -----------------------------------------------------------------------------
# EMAIL — Notificações transacionais
# -----------------------------------------------------------------------------
# Use Resend para desenvolvimento (plano gratuito generoso)
# https://resend.com

RESEND_API_KEY=""
# Formato: re_...

EMAIL_FROM="Tenora <noreply@tenora.com.br>"
# Endereço de envio — deve estar verificado no Resend


# -----------------------------------------------------------------------------
# WHATSAPP — Notificações (Plano Pro+)
# -----------------------------------------------------------------------------
# Use a API oficial do WhatsApp Business ou Twilio
# Configurar apenas a partir da Fase 3 (plano Pro)

WHATSAPP_API_URL=""
# URL da API WhatsApp Business ou Twilio

WHATSAPP_API_TOKEN=""
# Token de autenticação da API


# -----------------------------------------------------------------------------
# STORAGE — Cloudflare R2 (documentos de imóveis)
# -----------------------------------------------------------------------------
# Crie sua conta em: https://dash.cloudflare.com
# Acesse R2 → Create bucket → copie o Account ID do painel
#
# Para gerar as credenciais:
#   Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API Token
#   Permissões necessárias: Object Read & Write no bucket específico

R2_ACCOUNT_ID=""
# Account ID da sua conta Cloudflare
# Encontre em: Cloudflare Dashboard → lado direito → Account ID

R2_ACCESS_KEY_ID=""
# Access Key ID gerado no token de API do R2

R2_SECRET_ACCESS_KEY=""
# Secret Access Key gerado no token de API do R2
# NUNCA exponha esta chave — trate como senha

R2_BUCKET_NAME="tenora-documents"
# Nome do bucket criado no R2
# Recomendado: usar nomes diferentes por ambiente (tenora-documents-staging, tenora-documents-prod)

R2_PUBLIC_URL=""
# URL pública do bucket para acesso aos documentos
# Configure um domínio customizado no R2 ou use o endpoint público:
# Formato com domínio custom: https://docs.tenora.com.br
# Formato padrão R2:          https://pub-HASH.r2.dev (habilitar "Public Access" no bucket)
#
# CORS: Configure no bucket R2 para aceitar uploads do domínio do Vercel:
# [{"AllowedOrigins":["https://seu-app.vercel.app"],"AllowedMethods":["PUT"],"AllowedHeaders":["*"]}]


# -----------------------------------------------------------------------------
# OBSERVABILIDADE
# -----------------------------------------------------------------------------

SENTRY_DSN=""
# DSN do projeto no Sentry — encontre em: Sentry → Project Settings → Client Keys
# Formato: https://...@sentry.io/...

NEXT_PUBLIC_SENTRY_DSN=""
# Mesmo DSN — exposto ao frontend para capturar erros do browser

NEXT_PUBLIC_POSTHOG_KEY=""
# Chave pública do PostHog para analytics de produto
# Encontre em: PostHog → Project Settings → Project API Key
# Formato: phc_...

NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
# Use https://eu.posthog.com se preferir servidores europeus (GDPR)


# -----------------------------------------------------------------------------
# ASSINATURA DIGITAL (Fase 3 — Plano Pro)
# -----------------------------------------------------------------------------
# Configure apenas ao implementar o módulo de contratos digitais

CLICKSIGN_ACCESS_TOKEN=""
# Token de acesso da API ClickSign
# https://developers.clicksign.com

CLICKSIGN_ENV="sandbox"
# Valores: sandbox | production


# =============================================================================
# REFERÊNCIA RÁPIDA — Quais variáveis cada serviço usa
# =============================================================================
#
# apps/api (Fastify):
#   DATABASE_URL, DATABASE_URL_MIGRATOR, REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
#   CLERK_SECRET_KEY, CLERK_WEBHOOK_SECRET
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_*
#   PLUGGY_CLIENT_ID, PLUGGY_CLIENT_SECRET, PLUGGY_WEBHOOK_SECRET, PLUGGY_ENV
#   ASAAS_API_KEY, ASAAS_ENV, ASAAS_WEBHOOK_TOKEN
#   RESEND_API_KEY, EMAIL_FROM
#   R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET_NAME, R2_PUBLIC_URL
#   SENTRY_DSN, API_PORT, API_HOST, NODE_ENV, LOG_LEVEL
#
# apps/web (Next.js):
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, NEXT_PUBLIC_CLERK_*_URL
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#   NEXT_PUBLIC_API_URL, NEXT_PUBLIC_APP_URL
#   NEXT_PUBLIC_SENTRY_DSN, NEXT_PUBLIC_POSTHOG_KEY, NEXT_PUBLIC_POSTHOG_HOST
#
# packages/db (Prisma):
#   DATABASE_URL (aplicação), DATABASE_URL_MIGRATOR (migrations)
#   DATABASE_SHADOW_URL (validação de migrations)
#
# =============================================================================
